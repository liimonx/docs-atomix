{
  "name": "atomix-design-system-docs",
  "version": "1.0.0",
  "description": "Comprehensive documentation site for the Atomix Design System - 80+ components, design tokens, layouts, and AtomixGlass effects",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 200",
    "type-check": "tsc --noEmit",
    "test": "vitest run src/utils/__tests__/routeMapper.test.ts src/utils/__tests__/breadcrumbs.test.ts src/utils/__tests__/routeValidation.test.ts",
    "test:all": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "validate:components": "ts-node scripts/validate-component-metadata.ts",
    "generate:tokens": "ts-node --esm scripts/generateTokens.ts"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "typescript",
    "atomix",
    "ui-library",
    "design-tokens",
    "glass-morphism",
    "accessibility",
    "documentation"
  ],
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@phosphor-icons/react": "^2.1.10",
    "@playwright/test": "^1.56.1",
    "@shohojdhara/atomix": "^0.6.5",
    "culori": "^4.0.2",
    "date-fns": "^2.29.3",
    "framer-motion": "^12.38.0",
    "fs": "^0.0.1-security",
    "fuse.js": "^6.6.2",
    "gray-matter": "^4.0.3",
    "gsap": "^3.14.2",
    "immer": "^11.0.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.4.0",
    "react-intersection-observer": "^9.4.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-window": "^2.2.3",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^5.0.1",
    "remark-frontmatter": "^4.0.1",
    "remark-gfm": "^4.0.1",
    "sass-embedded": "^1.93.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/culori": "^4.0.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/ui": "^3.2.4",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "jsdom": "^21.1.0",
    "prettier": "^2.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
