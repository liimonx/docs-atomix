# Public site URL (sitemap, Open Graph, canonical links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: path to markdown docs directory for /api/markdown/*
# Defaults to ./atomix-doc-in-md/docs when unset
# ATOMIX_MARKDOWN_DOCS_PATH=/absolute/path/to/docs

# Optional: git repo cloned by npm run setup:markdown
# ATOMIX_MARKDOWN_REPO=https://github.com/your-org/atomix-doc-in-md
